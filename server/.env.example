# Copy to .env and fill in real values. Never commit .env.
DATABASE_URL="postgresql://user:password@host:5432/icta_attendance?sslmode=require"

# The public URL this API is served from (used in CORS and in activation/reset email links).
PUBLIC_APP_URL="http://localhost:3000"

# Sender address for activation/reset emails -- verify this exact address as
# a sender in Brevo (https://app.brevo.com/senders/list) so Brevo will send
# on its behalf.
GMAIL_SENDER_ADDRESS="youraccount@gmail.com"

# API key for Brevo (https://app.brevo.com/settings/keys/api). Emails are
# sent over Brevo's HTTPS API, not SMTP -- Render's free tier blocks all
# outbound SMTP ports, HTTPS is unaffected.
BREVO_API_KEY="xkeysib-..."

PORT=3000
NODE_ENV=development
